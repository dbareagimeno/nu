---
// Carril derecho de /api (200px): CTA "¿tu primer plugin?" (borde key) → /plugins,
// índice `§ en esta página` (las funciones/secciones de la página; activo bright
// vía scrollspy) y metadata "generada desde docs/api.md · <hash> · hace N días"
// tomada de git (la fuente de la referencia es docs/api.md, no estas páginas).
import { i18n } from '../../lib/i18n';
import { gitMeta } from '../../lib/gitmeta';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const base = import.meta.env.BASE_URL;
const es = i18n.es; // build-time en español; el swap a EN es en cliente (data-i18n)

// Etiqueta corta de una sección: último segmento de sus callables
// (`nu.fs.read` → `read`, `nu.fs.write / nu.fs.append` → `write / append`), o el
// texto limpio si el heading no nombra funciones (`Manipulación`).
function etiquetaSeccion(text: string): string {
  const limpio = text.replaceAll('⏸', '').replaceAll('[W]', '').trim();
  const nombres = limpio.match(/nu\.[\w.]+|[A-Z][A-Za-z]*:[a-z_]\w*/g);
  if (nombres) return nombres.map((n) => n.split(/[.:]/).pop()).join(' / ');
  return limpio;
}

const secciones = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, label: etiquetaSeccion(h.text) }));

const meta = gitMeta('docs/api.md');
const dias = meta
  ? meta.diasDesde === 0
    ? 'hoy'
    : `hace ${meta.diasDesde} día${meta.diasDesde === 1 ? '' : 's'}`
  : '';
---
<aside class="api-rail">
  <a class="cta" href={`${base}plugins`}>
    <div class="cta-title" data-i18n="ctaTitle">{es.ctaTitle}</div>
    <div class="cta-body" data-i18n="ctaBody">{es.ctaBody}</div>
    <span class="cta-link" data-i18n="ctaLink">{es.ctaLink}</span>
  </a>

  {secciones.length > 0 && (
    <>
      <div class="rail-h">§ <span data-i18n="onPage">{es.onPage}</span></div>
      <nav class="rail-secs">
        {secciones.map((s, i) => (
          <a href={`#${s.slug}`} class={i === 0 ? 'sec active' : 'sec'} data-sec={s.slug}>{s.label}</a>
        ))}
      </nav>
    </>
  )}

  <div class="rail-meta">
    {meta && (
      <div class="meta-gen">
        <span data-i18n="genFrom">{es.genFrom}</span><span class="key">{meta.hash}</span> · {dias}
      </div>
    )}
    <div class="meta-adr">
      <span data-i18n="sagrada">{es.sagrada}</span>{' '}
      <a href={`${base}docs/adr`} class="key" data-i18n="adrLink">{es.adrLink}</a>
    </div>
  </div>
</aside>
